<UserControl x:Class="DungeonCrawlerWorld.UI.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="10">
    <GroupBox Header="Sound and Visuals" Padding="10">
      <StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
          <Label Content="Fog:" Width="120"/>
          <ComboBox x:Name="FogComboBox" Width="180">
            <ComboBoxItem Content="No Fog"      Tag="0"/>
            <ComboBoxItem Content="Fast Fog"    Tag="1"/>
            <ComboBoxItem Content="Default Fog" Tag="2"/>
            <ComboBoxItem Content="Fancy Fog"   Tag="3"/>
          </ComboBox>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
          <Label Content="Lighting:" Width="120"/>
          <ComboBox x:Name="LightingComboBox" Width="180">
            <ComboBoxItem Content="No Shader Lighting"      Tag="0"/>
            <ComboBoxItem Content="Simple Shader Lighting"  Tag="1"/>
            <ComboBoxItem Content="Normal Shader Lighting"  Tag="2"/>
            <ComboBoxItem Content="Fancy Shader Lighting"   Tag="3"/>
            <ComboBoxItem Content="Highest Quality Lighting" Tag="4"/>
          </ComboBox>
        </StackPanel>
        <CheckBox x:Name="SoundCheckBox"
                  Content="Enable Physically Based Sound"
                  Margin="0,0,0,10"/>
        <Button Content="Save" Width="80"
                HorizontalAlignment="Right"
                Click="SaveButton_Click"/>
      </StackPanel>
    </GroupBox>
  </Grid>
</UserControl>