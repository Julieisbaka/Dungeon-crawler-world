<Window x:Class="Dungeon_Crawler_World.UI.MainMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dungeon Crawler World"
        Height="600"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a1a">

  <Window.Resources>
    <Style x:Key="MenuButton"
           TargetType="Button">
      <Setter Property="Background"
              Value="#2d2d2d"/>
      <Setter Property="Foreground"
              Value="#e0e0e0"/>
      <Setter Property="Width"
              Value="250"/>
      <Setter Property="Height"
              Value="50"/>
      <Setter Property="Margin"
              Value="0,10"/>
      <Setter Property="FontSize"
              Value="18"/>
      <Setter Property="FontFamily"
              Value="Segoe UI"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderThickness="2"
                    BorderBrush="#3f3f3f"
                    CornerRadius="5">
              <Grid>
                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                <Border x:Name="Overlay"
                        Background="#3fff"
                        Opacity="0"
                        CornerRadius="5"/>
              </Grid>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver"
                       Value="True">
                <Trigger.EnterActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <DoubleAnimation
                        Storyboard.TargetName="Overlay"
                        Storyboard.TargetProperty="Opacity"
                        To="0.1"
                        Duration="0:0:0.2"/>
                    </Storyboard>
                  </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <DoubleAnimation
                        Storyboard.TargetName="Overlay"
                        Storyboard.TargetProperty="Opacity"
                        To="0"
                        Duration="0:0:0.2"/>
                    </Storyboard>
                  </BeginStoryboard>
                </Trigger.ExitActions>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.Background>
      <RadialGradientBrush>
        <GradientStop Color="#1a1a1a"
                      Offset="0"/>
        <GradientStop Color="#0f0f0f"
                      Offset="1"/>
      </RadialGradientBrush>
    </Grid.Background>

    <StackPanel VerticalAlignment="Center"
                HorizontalAlignment="Center">

      <TextBlock Text="Dungeon Crawler"
                 FontSize="48"
                 Foreground="#e0e0e0"
                 FontWeight="Bold"
                 HorizontalAlignment="Center">
        <TextBlock.Effect>
          <DropShadowEffect Color="#7f000000"
                            ShadowDepth="3"
                            BlurRadius="5"/>
        </TextBlock.Effect>
      </TextBlock>

      <TextBlock Text="World"
                 FontSize="36"
                 Foreground="#ff6b6b"
                 FontWeight="Bold"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,50">
        <TextBlock.Effect>
          <DropShadowEffect Color="#7f000000"
                            ShadowDepth="3"
                            BlurRadius="5"/>
        </TextBlock.Effect>
      </TextBlock>

      <Button Style="{StaticResource MenuButton}"
              Click="PlayButton_Click">
        <StackPanel Orientation="Horizontal">
          <Path Data="M8,5V19L19,12L8,5Z"
                Fill="#e0e0e0"
                Width="20"
                Height="20"
                Margin="0,0,10,0"/>
          <TextBlock Text="Play"/>
        </StackPanel>
      </Button>

      <Button Style="{StaticResource MenuButton}"
              Click="SettingsButton_Click">
        <StackPanel Orientation="Horizontal">
          <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                Fill="#e0e0e0"
                Width="20"
                Height="20"
                Margin="0,0,10,0"/>
          <TextBlock Text="Settings"/>
        </StackPanel>
      </Button>

      <Button x:Name="NewGameButton" Style="{StaticResource MenuButton}" Click="NewGameButton_Click">
        <StackPanel Orientation="Horizontal">
          <Path Data="M8,5V19L19,12L8,5Z"
                Fill="#e0e0e0"
                Width="20"
                Height="20"
                Margin="0,0,10,0"/>
          <TextBlock Text="New Game"/>
        </StackPanel>
      </Button>      <Button x:Name="GameSavesButton" Style="{StaticResource MenuButton}" Click="GameSavesButton_Click">
        <StackPanel Orientation="Horizontal">
          <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                Fill="#e0e0e0"
                Width="20"
                Height="20"
                Margin="0,0,10,0"/>
          <TextBlock Text="Game Saves"/>
        </StackPanel>
      </Button>

      <Button x:Name="ExitButton" Style="{StaticResource MenuButton}" Click="ExitButton_Click" Margin="0,20,0,0">
        <StackPanel Orientation="Horizontal">
          <Path Data="M19,3H5C3.89,3 3,3.89 3,5V9H5V5H19V19H5V15H3V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5C21,3.89 20.1,3 19,3M10.08,15.58L11.5,17L16.5,12L11.5,7L10.08,8.41L12.67,11H3V13H12.67L10.08,15.58Z"
                Fill="#e0e0e0"
                Width="20"
                Height="20"
                Margin="0,0,10,0"/>
          <TextBlock Text="Exit"/>
        </StackPanel>
      </Button>
    </StackPanel>
  </Grid>
</Window>
