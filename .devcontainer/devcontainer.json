{
  "$schema": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainer.schema.json",
  "name": "Dungeon-crawler-world",
  "image": "mcr.microsoft.com/devcontainers/dotnet:7.0",
  // override default mount and user
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers-extra/features/prettier": "latest",
    "ghcr.io/devcontainers-extra/features/markdownlint-cli2": "latest",
    "ghcr.io/devcontainers/features/docker-in-docker": "latest"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode-remote.remote-containers",
        "esbenp.prettier-vscode",
        "EditorConfig.EditorConfig",
        "DavidAnson.vscode-markdownlint",
        "streetsidesoftware.code-spell-checker",
        "ms-dotnettools.csharp",
        "ms-dotnettools.csdevkit",
        "ryanluker.vscode-coverage-gutters",
        "formulahendry.dotnet-test-explorer"
      ],
      "settings": {
        "prettier.useEditorConfig": true,
        "prettier.insertPragma": false,
        "prettier.experimentalTernaries": true,
        "prettier.tabWidth": 2,
        "prettier.useTabs": false,
        "prettier.endOfLine": "crlf",
        "prettier.trailingComma": "none",
        "prettier.bracketSpacing": true,
        "prettier.embeddedLanguageFormatting": "auto",
        "json.format.enable": false,
        "json.schemas": [
          {
            "url": "https://raw.githubusercontent.com/Julieisbaka/Dungeon-crawler-world/refs/heads/Main/Scheme/schema.json",
            "fileMatch": [
              "**/*.json",
              "!.vscode/settings.json",
              "!.devcontainer/devcontainer.json",
              "!.vscode/**/*.json",
              "!.devcontainer/**/*.json",
              "!package-lock.json",
              "!config.json",
              "!Scheme/Shader.json"
            ]
          },
          {
            "url": "Scheme/Shader.json"
          }
        ],
        "json.validate.enable": true,
        "cSpell.words": [
          "Anson",
          "Baka",
          "cooldown",
          "devcontainers",
          "Dewatta",
          "esbenp",
          "Grawl",
          "Mathman",
          "Necro",
          "Perlin",
          "Julieisbaka",
          "Skolopendra"
        ],
        "files.associations": {
          ".prettierrc": "json"
        },
        "dotnet-test-explorer.testProjectPath": "**/*Tests.csproj",
        "omnisharp.enableRoslynAnalyzers": true,
        "omnisharp.enableEditorConfigSupport": true
      }
    }
  },
  "forwardPorts": [5000, 5001],
  "mounts": [
    "source=${env:HOME}${env:USERPROFILE}/.nuget/packages,target=/home/vscode/.nuget/packages,type=bind,consistency=cached"
  ],
  "postCreateCommand": "dotnet restore && dotnet build",
  "postStartCommand": "dotnet test",
  "remoteEnv": {
    "DOTNET_ENVIRONMENT": "Development",
    "ASPNETCORE_ENVIRONMENT": "Development"
  }
}

