{
  "prettier.useEditorConfig": true,
  "prettier.insertPragma": false,
  "prettier.experimentalTernaries": true,
  "prettier.tabWidth": 2,
  "prettier.useTabs": false,
  "prettier.endOfLine": "crlf",
  "prettier.trailingComma": "none",
  "prettier.bracketSpacing": true,
  "prettier.embeddedLanguageFormatting": "auto",
  "json.format.enable": false,
  "json.schemas": [
    {
      "url": "https://raw.githubusercontent.com/Julieisbaka/Dungeon-crawler-world/refs/heads/Main/Scheme/schema.json",
      "fileMatch": [
      "**/*.json",
      "!.vscode/settings.json",
      "!.devcontainer/devcontainer.json",
      "!.vscode/**/*.json",
      "!.devcontainer/**/*.json",
      "!package-lock.json",
      "!config.json",
      "!Shaders/Scheme.json"
      ]
      
    },
    {
      "url": "Shaders/Scheme.json"
    }
  ],
  "json.validate.enable": true,
  "cSpell.words": [
    "Anson",
    "Baka",
    "cooldown",
    "devcontainers",
    "Dewatta",
    "esbenp",
    "Grawl",
    "Julieisbaka",
    "Mathman",
    "Necro",
    "Perlin",
    "Skolopendra"
  ]
}
