{
  "$schema": "https://json.schemastore.org/package",
  "name": "dungeon-crawler-world",
  "description": "A thrilling adventure game set in a rich fantasy world. Explore dungeons, fight monsters, and uncover hidden treasures as you embark on an epic quest.",
  "author": "JulieISBaka",
  "version": "0.0.4.7",
  "license": "MIT",
  "dependencies": {
    "fs-extra": "^11.3.0",
    "path": "^0.12.7"
  },
  "devDependencies": {
    "prettier": "3.5.3",
    "markdownlint-cli2": "0.17.2"
  },
  "scripts": {
    "markdownlint-linelength": "markdownlint-cli2 ."
  },
  "prettier": {  "experimentalTernaries": true,
  "editorconfig": true,
  "embeddedLanguageFormatting": "auto",
  "useTabs": false,
  "tabWidth": 2,
  "endOfLine": "crlf",
  "trailingComma": "none",
  "bracketSpacing": true,
  "insertPragma": false,
  "plugins": []},
  "readme": "ReadME.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/JulieISBaka/dungeon-crawler-world.git",
    "directory": "./"
  }
}
