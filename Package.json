{
  "$schema": "https://json.schemastore.org/package",
  "version": "0.0.4.8",
  "dependencies": {
    "fs-extra": "^11.3.0",
    "path": "^0.12.7"
  },
  "devDependencies": {
    "prettier": "3.5.3",
    "markdownlint-cli2": "0.17.2"
  },
  "scripts": {
    "markdownlint-linelength": "markdownlint-cli2 ."
  },
  "prettier": {
  "experimentalTernaries": true,
  "editorconfig": true,
  "embeddedLanguageFormatting": "auto",
  "useTabs": false,
  "tabWidth": 2,
  "endOfLine": "crlf",
  "trailingComma": "none",
  "bracketSpacing": true,
  "insertPragma": false,
  "plugins": []
