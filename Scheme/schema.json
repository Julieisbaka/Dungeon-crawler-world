{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Dungeon crawler world Schema",
  "description": "Contains all properties used for json data files within the dungeon crawler world fan-made game.",
  "type": "object",
  "properties": {
    "prerequisites": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "attribute": {
            "type": "string",
            "enum": [
              "Charisma",
              "Strength",
              "Intelligence",
              "Dexterity",
              "Constitution",
              "Wisdom"
            ]
          },
          "value": {
            "type": "number",
            "minimum": 1
          }
        },
        "required": ["attribute", "value"]
      },
      "description": "This is a list of all the prerequisite attributes and their minimum values needed to use this ability."
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "property": {
            "type": "string",
            "enum": [
              "classes",
              "views",
              "abilities",
              "sub_classes",
              "level",
              "skills"
            ],
            "description": "The property that is required."
          },
          "value": {
            "type": ["string", "number"],
            "description": "The value that the property must have."
          }
        },
        "required": ["property", "value"]
      },
      "description": "This is a list of all the requirements needed to unlock this ability."
    },
    "abilities": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": {
            "type": "string",
            "enum": [
              "Null",
              "None",
              "Blunt",
              "Fire",
              "heat",
              "poison",
              "electric",
              "ranged",
              "magic",
              "melee",
              "sonic",
              "physic",
              "direct",
              "indirect",
              "dot",
              "aoe",
              "heal",
              "buff",
              "attack"
            ]
          },
          "cost": { "type": "number" },
          "cooldown": { "type": "number" },
          "range": { "type": "number" },
          "duration": { "type": "number" }
        },
        "required": ["id", "name"]
      },
      "description": "This is a list of available abilities."
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "attribute": {
            "type": "string",
            "enum": [
              "Charisma",
              "Strength",
              "Intelligence",
              "Dexterity",
              "Constitution",
              "Wisdom"
            ]
          },
          "level": {
            "type": "number",
            "minimum": 0
          }
        },
        "required": ["id", "name", "attribute"]
      },
      "description": "List of character skills and proficiencies."
    },
    "classes": {
      "type": "array",
      "description": "This is the list of classes provided by the input or connected to the inputs."
    },
    "sub_classes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "This is the list of subclasses connected to the input classes."
    },
    "description": {
      "type": "string",
      "description": "This is the description of the thing."
    },
    "type": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Null",
          "None",
          "Blunt",
          "Fire",
          "heat",
          "poison",
          "electric",
          "ranged",
          "magic",
          "melee",
          "sonic",
          "physic",
          "direct",
          "indirect",
          "dot",
          "aoe",
          "heal",
          "buff",
          "attack"
        ]
      },
      "description": "This is the type of the thing."
    },
    "level": {
      "oneOf": [
        {
          "type": "number",
          "minimum": 0,
          "description": "This is the level of the thing."
        },
        {
          "type": "string",
          "enum": ["x", "?", "unknown"],
          "description": "This allows for variable and unknown level descriptions."
        }
      ],
      "description": "This is the level of the thing."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "This is the name of the thing."
    },
    "range": {
      "type": "number",
      "minimum": 0,
      "description": "This is the range of the ability. This is measured in Centimeters.",
      "$comment": "Its measured in Centimeters because that is the smallest measurement unit used regarding range."
    },
    "duration": {
      "type": "number",
      "minimum": 0,
      "description": "This is the duration of the ability."
    },
    "cost": {
      "type": "number",
      "description": "This is the cost of using the ability."
    },
    "cooldown": {
      "type": "number",
      "minimum": 0,
      "description": "This is the cooldown period for using the ability."
    },
    "Duration_level_mod": { "type": "number" },
    "cooldown_level_mod": { "type": "number" },
    
  }
}

