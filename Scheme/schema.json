{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Dungeon Crawler World Schema",
  "description": "Schema for the Dungeon Crawler World game data files. Defines all available properties and their validation rules.",
  "$comment": "Version 2.0 - Updated with enhanced validation and documentation",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "prerequisites": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": {
          "oneOf": [
            { "$ref": "#/definitions/attributeValue" },
            { "$ref": "#/properties/level" },
            { "$ref": "#/properties/duration" },
            { "$ref": "#/properties/range" },
            { "$ref": "#/properties/cost" },
            { "$ref": "#/properties/cooldown" }
          ]
        }
      },
      "description": "List of prerequisites where each object can contain any schema property as a key with its required value"
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": {
          "oneOf": [
            { "$ref": "#/definitions/skillRequirement" },
            { "$ref": "#/properties/level" },
            { "$ref": "#/properties/duration" },
            { "$ref": "#/properties/range" },
            { "$ref": "#/properties/cost" },
            { "$ref": "#/properties/cooldown" },
            { 
              "type": "object",
              "additionalProperties": true
            }
          ]
        }
      },
      "description": "List of requirements where each object can contain any schema property as a key with its required value"
    },
    "abilities": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_]*$",
            "description": "Unique identifier for the ability",
            "examples": ["fireball", "healing_touch"],
            "errorMessage": "Ability ID must start with a letter and contain only letters, numbers, and underscores"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "description": "Display name of the ability",
            "examples": ["Fireball", "Healing Touch"]
          },
          "description": {
            "type": "string",
            "maxLength": 500
          },
          "type": {
            "type": "array",
            "items": {
              "$ref": "#/definitions/damageTypes"
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "target_type": {
            "type": "string",
            "enum": ["self", "single", "area", "line", "cone"],
            "description": "How the ability targets entities",
            "default": "single"
          },
          "scaling": {
            "type": "object",
            "properties": {
              "attribute": {
                "$ref": "#/definitions/attributes"
              },
              "factor": {
                "type": "number",
                "minimum": 0,
                "maximum": 5
              }
            },
            "required": ["attribute", "factor"]
          },
          "cost": { "type": "number" },
          "cooldown": { "type": "number" },
          "range": { "type": "number" },
          "duration": { "type": "number" }
        },
        "required": ["id", "name", "type"]
      },
      "description": "This is a list of available abilities."
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "attribute": {
            "type": "string",
            "enum": [
              "Charisma",
              "Strength",
              "Intelligence",
              "Dexterity",
              "Constitution",
              "Wisdom"
            ]
          },
          "level": {
            "type": "number",
            "minimum": 0
          },
          "specializations": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "passive_effects": {
            "type": "array",
            "items": {
              "$ref": "#/definitions/effect"
            }
          }
        },
        "required": [
          "id", 
          "name", 
          "attribute"
        ]
      },
      "description": "List of character skills and proficiencies."
    },
    "classes": {
      "type": "array",
      "description": "This is the list of classes provided by the input or connected to the inputs."
    },
    "sub_classes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "This is the list of subclasses connected to the input classes."
    },
    "description": {
      "type": "string",
      "description": "This is the description of the thing."
    },
    "type": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "Null",
            "None",
            "Blunt",
            "Fire",
            "Heat",
            "Poison",
            "Electric",
            "Ranged",
            "Magic",
            "Melee",
            "Sonic",
            "Physic",
            "Direct",
            "Indirect",
            "DOT",
            "AOE",
            "Heal",
            "Buff",
            "Attack",
            "Divine",
            "Artifact",
            "Weapon",
            "Armor",
            "Consumable",
            "Skill",
            "Race",
            "Class",
            "God"
          ]
        },
        {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "Null",
              "None",
              "Blunt",
              "Fire",
              "Heat",
              "Poison",
              "Electric",
              "Ranged",
              "Magic",
              "Melee",
              "Sonic",
              "Physic",
              "Direct",
              "Indirect",
              "DOT",
              "AOE",
              "Heal",
              "Buff",
              "Attack",
              "Divine",
              "Artifact",
              "Weapon",
              "Armor",
              "Consumable",
              "Skill",
              "Race",
              "Class",
              "God"
            ]
          }
        }
      ],
      "description": "This is the type of the thing."
    },
    "level": {
      "oneOf": [
        {
          "type": "number",
          "minimum": 0,
          "description": "This is the level of the thing."
        },
        {
          "type": "string",
          "enum": [
            "x", 
            "?", 
            "unknown"
          ],
          "description": "This allows for variable and unknown level descriptions."
        }
      ],
      "description": "This is the level of the thing."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "This is the name of the thing."
    },
    "range": {
      "type": "number",
      "minimum": 0,
      "description": "This is the range of the ability. This is measured in Centimeters.",
      "$comment": "Its measured in Centimeters because that is the smallest measurement unit used regarding range."
    },
    "duration": {
      "type": "number",
      "minimum": 0,
      "description": "This is the duration of the ability."
    },
    "cost": {
      "type": "number",
      "description": "This is the cost of using the ability."
    },
    "cooldown": {
      "type": "number",
      "minimum": 0,
      "description": "This is the cooldown period for using the ability."
    },
    "Duration_level_mod": {
      "type": "number",
      "description": "This property is deprecated and should not be used!",
      "$comment": "This property should not be used!"
    },
    "cooldown_level_mod": {
      "type": "number",
      "description": "This property is deprecated and should not be used!",
      "$comment": "This property should not be used!"
    },
    "effects": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "duration": { "type": "number" },
          "type": { "$ref": "#/properties/type" }
        }
      }
    },
    "divine_aspects": {
      "type": "object",
      "properties": {
        "domains": {
          "type": "array",
          "items": { "type": "string" }
        },
        "worshippers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "artifacts": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "item_properties": {
      "type": "object",
      "properties": {
        "equippable": { "type": "boolean" },
        "consumable": { "type": "boolean" },
        "charges": { "type": "number" },
        "durability": { "type": "number" },
        "value": { "type": "number" }
      }
    },
    "race_properties": {
      "type": "object",
      "properties": {
        "base_stats": {
          "type": "object",
          "properties": {
            "strength": { "type": "number" },
            "dexterity": { "type": "number" },
            "constitution": { "type": "number" },
            "intelligence": { "type": "number" },
            "wisdom": { "type": "number" },
            "charisma": { "type": "number" }
          }
        },
        "size": { "type": "string" },
        "speed": { "type": "number" },
        "languages": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "equipment_slot": {
      "type": "string",
      "enum": [
        "head",
        "chest",
        "legs",
        "feet",
        "hands",
        "mainHand",
        "offHand",
        "ring",
        "necklace",
        "belt"
      ],
      "description": "Equipment slot where an item can be equipped"
    }
  },
  "definitions": {
    "attributeValue": {
      "type": "number",
      "minimum": 1,
      "description": "Value for attributes like Strength, Dexterity, etc."
    },
    "skillRequirement": {
      "type": "object",
      "properties": {
        "id": { 
          "type": "string" 
        },
        "level": { 
          "type": "number", 
          "minimum": 0 
        }
      },
      "required": [
        "id", 
        "level"
      ]
    },
    "damageTypes": {
      "type": "string",
      "enum": [
        "physical",
        "fire",
        "ice",
        "lightning",
        "poison",
        "holy",
        "shadow",
        "arcane"
      ],
      "description": "Available damage types in the game"
    },
    "attributes": {
      "type": "string",
      "enum": [
        "strength",
        "dexterity",
        "constitution", 
        "intelligence",
        "wisdom",
        "charisma"
      ],
      "description": "Core character attributes"
    },
    "effect": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
        },
        "name": {
          "type": "string"
        },
        "duration": {
          "type": "number",
          "minimum": 0
        },
        "stackable": {
          "type": "boolean",
          "default": false
        },
        "max_stacks": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        },
        "modifiers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "attribute": {
                "$ref": "#/definitions/attributes"
              },
              "value": {
                "type": "number"
              },
              "type": {
                "enum": ["flat", "percentage"]
              }
            },
            "required": ["attribute", "value", "type"]
          }
        }
      },
      "required": ["id", "name"]
    }
  },
  "errorMessage": {
    "type": "Must be a valid JSON object",
    "required": {
      "name": "Name is required",
      "id": "ID is required"
    },
    "properties": {
      "level": "Level must be a number >= 0 or one of: 'x', '?', 'unknown'",
      "range": "Range must be a positive number in centimeters",
      "duration": "Duration must be a positive number"
    }
  },
  "examples": [
    {
      "name": "Fireball",
      "type": ["fire", "arcane"],
      "range": 1000,
      "duration": 0,
      "cost": 25,
      "cooldown": 5,
      "requirements": [
        {
          "skills": {
            "id": "destruction_magic",
            "level": 3
          }
        }
      ],
      "description": "A powerful fire spell that engulfs enemies in flames."
    },
    {
      "name": "Ice Lance",
      "id": "ice_lance",
      "type": ["ice", "physical"],
      "target_type": "line",
      "scaling": {
        "attribute": "intelligence",
        "factor": 1.5
      },
      "effects": [
        {
          "id": "chilled",
          "name": "Chilled",
          "duration": 5,
          "stackable": true,
          "max_stacks": 3,
          "modifiers": [
            {
              "attribute": "dexterity",
              "value": -10,
              "type": "percentage"
            }
          ]
        }
      ]
    }
  ]
}

