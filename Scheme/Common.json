{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "properties": {
    "name": {
      "type": "string",
      "description": "The name.",
      "minLength": 1
    },
    "icon": {
      "type": "string",
      "description": "Path to an icon file.",
      "pattern": "^.*\\.(png|jpg|jpeg)$"
    },
    "description": {
      "oneOf": [
        {
          "type": "string",
          "description": "A brief description in Markdown format.",
          "minLength": 1,
          "contentMediaType": "text/markdown"
        },
        {
          "type": "string",
          "description": "Path to a markdown file.",
          "pattern": "^.*\\.md$"
        }
      ]
    }
  }
}
