{
    "$schema": "https://json-schema.org/draft-07/schema#",
    "properties": {
        "name": {
            "type": "string",
            "description": "The player's chosen character name"
        },
        "level": {
            "type": "number",
            "description": "The player's current experience level"
        },
        "spells": {
            "type": "object",
            "description": "A collection of known spells and their levels"
        },
        "inventory": {
            "type": "object",
            "description": "Items and equipment owned by the player"
        },
        "skills": {
            "type": "object",
            "description": "Character skills and their current levels"
        },
        "coins": {
            "type": "integer",
            "description": "Amount of currency the player possesses"
        },
        "sub_classes": {
            "type": "array",
            "description": "Additional specialized classes the player has acquired",
            "items": {
                "type": "string"
            }
        },
        "class": {
            "type": "string",
            "description": "The player's primary character class"
        },        
        "race": {
            "type": "string",
            "description": "The player's chosen character race"
        },
        "has_manager": {
            "type": "boolean",
            "default": false
        },
        "current_floor": {
            "type": "integer",
            "description": "The current floor the player is on"
        },
        "stats": {
            "type": "object",
            "properties": {
                "strength": {
                    "type": "integer",
                    "maximum": 300,
                    "minimum": 0
                },
                "dexterity": {
                    "type": "integer",
                    "maximum": 300,
                    "minimum": 0
                },
                "intelligence": {
                    "type": "integer",
                    "maximum": 300,
                    "minimum": 0
                },
                "charisma": {
                    "type": "integer",
                    "maximum": 300,
                    "minimum": 0
                },
                "constitution": {
                    "type": "integer",
                    "maximum": 300,
                    "minimum": 0
                }
            }
        }
    }
}
