{
    "$schema": "https://json-schema.org/draft-07/schema#",
    "properties": {
        "name": {
            "type": "string"
        },
        "level": {
            "type": "number"
        },
        "spells": {
            "type": "object"
        },
        "inventory": {
            "type": "object"
        },
        "skills": {
            "type": "object"
        },
        "coins": {
            "type": "integer"
        },
        "sub_classes": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "class": {
            "type": "string"
        },        
        "race": {
            "type": "string"
        },
        "has_manager": {
            "type": "boolean",
            "default": false
        },
        "current_floor": {
            "type": "integer",
            "description": "The current floor the player is on"
        },
        "stats": {
            "type": "object",
            "properties": {
                "strength": {
                    "type": "integer",
                    "maximum": 300,
                    "minimum": 0
                },
                "dexterity": {
                    "type": "integer",
                    "maximum": 300,
                    "minimum": 0
                },
                "intelligence": {
                    "type": "integer",
                    "maximum": 300,
                    "minimum": 0
                },
                "charisma": {
                    "type": "integer",
                    "maximum": 300,
                    "minimum": 0
                },
                "constitution": {
                    "type": "integer",
                    "maximum": 300,
                    "minimum": 0
                }
            }
        }
    }
}
